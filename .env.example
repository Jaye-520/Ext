# Ext 配置文件模板
# 复制这份文件为 .env 并修改其中的值

# ============== 数据库配置 ==============
# 爬虫数据库(存储抖音视频数据)
CRAWLER_DB_HOST=localhost
CRAWLER_DB_PORT=3306
CRAWLER_DB_USER=root
CRAWLER_DB_PASSWORD=123456
CRAWLER_DB_NAME=media_crawler_pro

# ============== Redis配置 ==============
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_password_here  # 如果需要密码，取消注释并修改

# ============== 定时任务配置 ==============
SCHEDULER_INTERVAL_MINUTES=5
SCHEDULER_BATCH_SIZE=100

# ============== Worker配置 ==============
WORKER_CONCURRENCY=2
ASR_PROVIDER=faster-whisper  # faster-whisper 或 aliyun

# ============== Faster-Whisper配置 ==============
# 模型: tiny/base/small/medium/large
WHISPER_MODEL_SIZE=tiny
# 设备: cpu / cuda
WHISPER_DEVICE=cpu

# ============== 阿里云ASR配置(可选) ==============
# ALIYUN_ASR_APP_KEY=
# ALIYUN_ASR_ACCESS_KEY=
# ALIYUN_ASR_SECRET_KEY=
# ALIYUN_ASR_REGION=cn-shanghai